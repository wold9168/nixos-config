{
  "nix.serverSettings": {
    "nixd": {
      "nixpkgs": {
        "expr": "import <nixpkgs> { }"
      },
      "formatting": {
        "command": ["nixfmt"]
      },
      "options": {
        "nixos": {
          "expr": "(builtins.getFlake (builtins.toString ./.)).nixosConfigurations.default.options"
        },
        "home-manager": {
          "expr": "(builtins.getFlake (builtins.toString ./.)).nixosConfigurations.default.options.home-manager.users.type.getSubOptions []"
        }
      },
      "diagnostic": {
        "suppress": ["sema-extra-with"]
      }
    }
  }
}
